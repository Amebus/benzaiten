{
  "name": "Benzaiten UI",
  "dockerComposeFile": ["../../../docker-compose.dev.yml"],
  "service": "ui-dev",
  "workspaceFolder": "/workspace/src/UI",
  "forwardPorts": [3000],
  "postCreateCommand": "bun install",
  "postStartCommand": "bun run dev",
  "containerEnv": {
    "BUN_INSTALL_CACHE_DIR": "/home/.bun/install/cache"
  },
  "mounts": [
    "source=${localEnv:HOME}/Progetti/informatica/bun/cache,target=/home/.bun/install/cache,type=bind"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "oven.bun-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer",
        "wmaurer.change-case",
        "davidanson.vscode-markdownlint",
        "yzhang.markdown-all-in-one",
        "johnpapa.vscode-peacock"
      ]
    }
  }
}