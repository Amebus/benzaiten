{
  "name": "benzaiten",
  "image": "bun-alpine:1.3.11",
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"vitest.explorer",
				"wmaurer.change-case",
				"davidanson.vscode-markdownlint",
				"yzhang.markdown-all-in-one",
				"astro-build.astro-vscode",
				"johnpapa.vscode-peacock"
			]
		}
	},
	"containerEnv": {
		"BUN_INSTALL_CACHE_DIR": "/home/.bun/install/cache"
	},
  "forwardPorts": [61000],
	"mounts": [
     "source=${localEnv:HOME}/Progetti/informatica/bun/cache,target=/home/.bun/install/cache,type=bind"
  ],
	"runArgs": ["--name", "benzaiten_devcontainer"]
}