# Variabili d'ambiente per Benzaiten
# Copia questo file in .env e modifica i valori

# PostgreSQL
POSTGRES_PASSWORD=cambia_questa_password_sicura

# MinIO (Object Storage per le immagini)
MINIO_ROOT_USER=benzaiten
MINIO_ROOT_PASSWORD=cambia_questa_password_minio

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=cambia_questa_password_keycloak
KEYCLOAK_CLIENT_SECRET=il_tuo_client_secret_keycloak

# NextAuth (genera con: openssl rand -base64 32)
NEXTAUTH_SECRET=genera_con_openssl_rand_base64_32
